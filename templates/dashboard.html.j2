<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Serene · AI Performance — {{ account.name }}</title>
  <meta name="theme-color" content="#050505" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Serene AI" />
  <meta name="mobile-web-app-capable" content="yes" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon-32.png" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{font-size:15px;scroll-behavior:smooth;scroll-padding-top:24px}
    body{font-family:'Inter Tight',system-ui,sans-serif;background:var(--obsidian);color:var(--text-1);-webkit-font-smoothing:antialiased;font-feature-settings:"ss01","cv11","tnum";letter-spacing:-.011em;line-height:1.5;overflow-x:hidden}
    img,svg{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    button{background:none;border:0;cursor:pointer;color:inherit;font:inherit}
    code{font-family:'JetBrains Mono',monospace;font-size:.88em}
    ::selection{background:var(--accent);color:#fff}
    :root{
      --obsidian:#050505;--surface-1:#0a0a0c;--surface-2:#121214;--surface-3:#1a1a1d;
      --border:rgba(255,255,255,.06);--border-lit:rgba(255,255,255,.10);--border-glow:rgba(255,255,255,.18);
      --text-1:#fafafa;--text-2:#a1a1aa;--text-3:#71717a;--text-4:#52525b;
      --accent:#FF5722;--accent-2:#FFB800;--mint:#34d399;--rose:#f43f5e;--blue:#6366f1;--paper:#FAFAF8;
      --grad-accent:linear-gradient(135deg,#FF5722 0%,#FFB800 100%);
      --grad-mint:linear-gradient(135deg,#34d399 0%,#6ee7b7 100%);
      --grad-rose:linear-gradient(135deg,#f43f5e 0%,#FF5722 100%);
      --r-md:14px;--r-lg:20px;--r-xl:28px;
      --ease:cubic-bezier(0.16,1,0.3,1);
    }
    .app{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
    .sidebar{position:sticky;top:0;height:100vh;background:var(--surface-1);border-right:1px solid var(--border);padding:24px 18px;display:flex;flex-direction:column;gap:18px;overflow-y:auto}
    .sidebar-brand{display:flex;align-items:center;gap:10px;padding:6px 8px;font-weight:700;font-size:15px;letter-spacing:-.02em}
    .sidebar-brand-mark{width:28px;height:28px;border-radius:8px;background:var(--grad-accent);display:flex;align-items:center;justify-content:center;font-family:'Instrument Serif',serif;font-style:italic;font-size:16px;color:#fff;box-shadow:0 4px 14px rgba(255,87,34,.4)}
    .sidebar-brand small{color:var(--text-3);font-weight:500;font-size:11px;letter-spacing:.04em}
    .sidebar-section{display:flex;flex-direction:column;gap:2px}
    .sidebar-section-label{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--text-4);padding:0 8px;margin-bottom:6px}
    .sidebar-link{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;color:var(--text-2);font-size:13px;font-weight:500;cursor:pointer}
    .sidebar-link.active{background:rgba(255,87,34,.12);color:var(--text-1);position:relative}
    .sidebar-link.active::before{content:"";position:absolute;left:0;top:6px;bottom:6px;width:2px;background:var(--accent);border-radius:99px}
    .sidebar-link-icon{width:14px;height:14px;flex-shrink:0;color:var(--text-3)}
    .sidebar-link.active .sidebar-link-icon{color:var(--accent)}
    .sidebar-link-badge{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;background:var(--rose);color:#fff;padding:2px 6px;border-radius:99px;font-weight:700}
    .sidebar-footer{margin-top:auto;padding:14px 10px;border-top:1px solid var(--border);font-size:11px;color:var(--text-4)}
    .main{padding:24px 32px 80px;min-width:0}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:32px;flex-wrap:wrap}
    .topbar > .topbar-title{flex:1;min-width:0}
    .topbar-title h1{font-size:1.875rem;font-weight:700;letter-spacing:-.025em;line-height:1.1}
    .topbar-title h1 .serif{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:var(--text-2)}
    .topbar-title p{font-size:13px;color:var(--text-3);margin-top:6px}
    .topbar-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .pill-group{display:inline-flex;background:var(--surface-1);border:1px solid var(--border);border-radius:99px;padding:3px}
    .pill-toggle{padding:7px 14px;border-radius:99px;font-size:12px;font-weight:600;color:var(--text-3);letter-spacing:-.005em}
    .pill-toggle.active{background:var(--surface-3);color:var(--text-1)}
    .live-pill{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:99px;background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.20);font-size:11px;font-weight:600;color:var(--mint);letter-spacing:.04em;text-transform:uppercase}
    .live-pill.warn{background:rgba(255,184,0,.08);border-color:rgba(255,184,0,.25);color:var(--accent-2)}
    .live-pill::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor;box-shadow:0 0 8px currentColor;animation:pulse 2.4s var(--ease) infinite}
    @keyframes pulse{0%{box-shadow:0 0 0 0 currentColor}70%{box-shadow:0 0 0 8px transparent}100%{box-shadow:0 0 0 0 transparent}}
    /* Scroll progress bar (top) */
    .scroll-progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:200;background:var(--grad-accent);box-shadow:0 0 12px rgba(255,87,34,.6);transition:width .08s linear}
    /* Action button (regen) */
    .action-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 12px;border-radius:99px;background:var(--surface-3);border:1px solid var(--border-lit);color:var(--text-2);font-size:12px;font-weight:600;cursor:pointer;transition:.2s var(--ease)}
    .action-btn:hover{color:var(--text-1);background:var(--surface-2);border-color:var(--border-glow);transform:translateY(-1px)}
    .action-btn svg{width:13px;height:13px}
    .action-btn.spinning svg{animation:spin 1s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    /* Tooltip (CSS-only) */
    [data-tip]{position:relative;cursor:help}
    [data-tip]::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);padding:6px 10px;border-radius:8px;background:#000;color:#fff;font-size:11px;font-weight:500;font-family:'Inter Tight',sans-serif;letter-spacing:-.005em;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s var(--ease);z-index:50;border:1px solid var(--border-lit)}
    [data-tip]:hover::after{opacity:1}
    /* Toast */
    .toast{position:fixed;top:20px;right:20px;background:var(--surface-2);border:1px solid var(--border-lit);border-radius:12px;padding:12px 18px;font-size:13px;font-weight:500;color:var(--text-1);box-shadow:var(--shadow-lg);z-index:100;transform:translateY(-120%);opacity:0;transition:transform .3s var(--ease),opacity .3s var(--ease)}
    .toast.show{transform:translateY(0);opacity:1}
    .toast.success{border-color:rgba(52,211,153,.4)}
    .toast.error{border-color:rgba(244,63,94,.4)}
    /* Sidebar links — clickable */
    .sidebar-link{text-decoration:none}
    .sidebar-link:hover{background:rgba(255,255,255,.04);color:var(--text-1)}
    /* Pill toggle interactivity */
    .pill-toggle{cursor:pointer;border:none;background:none}
    /* Campaign row clickable */
    .campaigns-table tbody tr{cursor:pointer;transition:background .15s var(--ease)}
    .campaigns-table tbody tr:hover{background:rgba(255,87,34,.04)}
    /* Post row click feedback */
    .post-row{cursor:pointer}
    .post-row:hover .post-thumb{border-color:var(--accent)}
    /* Urgent Actions panel */
    .urgent-shell{
      margin-bottom:48px;background:linear-gradient(135deg,rgba(244,63,94,.12) 0%,rgba(255,87,34,.08) 100%);
      border:1px solid rgba(244,63,94,.30);border-radius:var(--r-xl);padding:28px;
      position:relative;overflow:hidden;
    }
    .urgent-shell::before{
      content:"";position:absolute;top:0;left:0;right:0;height:3px;
      background:linear-gradient(90deg,#f43f5e,#FF5722);
      animation:pulse-bar 2.4s ease-in-out infinite;
    }
    @keyframes pulse-bar{0%,100%{opacity:1}50%{opacity:.6}}
    .urgent-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:14px}
    .urgent-head h2{font-size:22px;font-weight:800;letter-spacing:-.025em;color:var(--text-1);display:flex;align-items:center;gap:12px}
    .urgent-head .siren{display:inline-flex;width:36px;height:36px;border-radius:10px;background:rgba(244,63,94,.15);align-items:center;justify-content:center;font-size:18px;animation:siren 1.5s ease-in-out infinite}
    @keyframes siren{0%,100%{transform:scale(1)}50%{transform:scale(1.1);background:rgba(244,63,94,.25)}}
    .urgent-count{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--rose);background:rgba(244,63,94,.10);padding:6px 12px;border-radius:99px;border:1px solid rgba(244,63,94,.25)}
    .urgent-list{display:flex;flex-direction:column;gap:10px}
    .urgent-card{
      display:grid;grid-template-columns:60px 1fr auto;gap:18px;align-items:center;
      padding:18px 20px;background:rgba(5,5,5,.5);border:1px solid var(--border);border-radius:var(--r-md);
      transition:.2s var(--ease);cursor:pointer;
    }
    .urgent-card:hover{transform:translateX(3px);border-color:rgba(244,63,94,.35);background:rgba(244,63,94,.04)}
    .urgent-card.critical{border-left:3px solid var(--rose)}
    .urgent-card.warning{border-left:3px solid var(--accent-2)}
    .urgent-action-tag{
      font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:800;letter-spacing:.06em;
      padding:8px 10px;border-radius:8px;text-align:center;line-height:1.2;
    }
    .urgent-action-tag.critical{background:var(--rose);color:#fff;box-shadow:0 4px 12px rgba(244,63,94,.4)}
    .urgent-action-tag.warning{background:var(--accent-2);color:#0a0a0a}
    .urgent-body h4{font-size:15px;font-weight:600;color:var(--text-1);letter-spacing:-.005em;margin-bottom:6px;line-height:1.3}
    .urgent-body .reason{font-size:13px;color:var(--text-2);line-height:1.5;margin-bottom:6px}
    .urgent-body .impact{font-size:12px;color:var(--rose);font-weight:600;display:flex;align-items:center;gap:6px}
    .urgent-body .impact::before{content:"💸"}
    .urgent-go{
      font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.06em;
      padding:8px 14px;border-radius:99px;background:var(--text-1);color:var(--obsidian);
      transition:.2s var(--ease);text-decoration:none;display:inline-flex;align-items:center;gap:6px;
    }
    .urgent-go:hover{transform:scale(1.05);box-shadow:0 6px 20px rgba(255,255,255,.15)}
    .urgent-empty{
      text-align:center;padding:48px 20px;background:rgba(52,211,153,.04);border:1px solid rgba(52,211,153,.20);border-radius:var(--r-md);
      color:var(--mint);font-weight:600;font-size:14px;
    }
    .urgent-empty::before{content:"✓ ";font-size:18px}
    @media(max-width:640px){
      .urgent-card{grid-template-columns:1fr;gap:10px}
      .urgent-action-tag{align-self:flex-start}
    }
    /* ─── Detail Modal ─── */
    .modal-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:24px;animation:overlayIn .25s var(--ease)}
    .modal-overlay.active{display:flex}
    @keyframes overlayIn{from{opacity:0}to{opacity:1}}
    .modal{
      width:100%;max-width:720px;max-height:90vh;overflow-y:auto;
      background:var(--surface-1);border:1px solid var(--border-lit);border-radius:var(--r-xl);
      box-shadow:var(--shadow-xl);
      animation:modalIn .35s var(--ease);
    }
    @keyframes modalIn{from{opacity:0;transform:translateY(20px) scale(.96)}to{opacity:1;transform:none}}
    .modal-head{
      padding:24px 28px 20px;border-bottom:1px solid var(--border);
      display:flex;justify-content:space-between;align-items:flex-start;gap:18px;
      position:sticky;top:0;background:var(--surface-1);z-index:2;border-radius:var(--r-xl) var(--r-xl) 0 0;
    }
    .modal-head h3{font-size:20px;font-weight:700;letter-spacing:-.02em;line-height:1.3;margin-bottom:6px}
    .modal-head .subtitle{font-size:13px;color:var(--text-3);line-height:1.5}
    .modal-tag{
      display:inline-block;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:800;
      letter-spacing:.06em;padding:6px 10px;border-radius:6px;margin-bottom:12px;
    }
    .modal-tag.critical{background:var(--rose);color:#fff}
    .modal-tag.warning{background:var(--accent-2);color:#0a0a0a}
    .modal-close{
      width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.06);border:1px solid var(--border);
      cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-2);
      transition:.2s var(--ease);flex-shrink:0;
    }
    .modal-close:hover{background:rgba(255,255,255,.10);color:var(--text-1);transform:rotate(90deg)}
    .modal-body{padding:24px 28px}
    .modal-body h4{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--text-3);margin:24px 0 10px}
    .modal-body h4:first-child{margin-top:0}
    .modal-body p{font-size:14px;color:var(--text-2);line-height:1.7}
    .modal-body p strong{color:var(--text-1);font-weight:600}
    .modal-steps{display:flex;flex-direction:column;gap:14px;margin-top:14px}
    .modal-step{
      display:grid;grid-template-columns:32px 1fr;gap:14px;align-items:flex-start;
      padding:14px 16px;background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:var(--r-md);
    }
    .modal-step-num{
      width:28px;height:28px;border-radius:50%;background:var(--accent);color:#fff;
      display:flex;align-items:center;justify-content:center;
      font-family:'JetBrains Mono',monospace;font-weight:700;font-size:12px;flex-shrink:0;
      box-shadow:0 4px 12px rgba(255,87,34,.3);
    }
    .modal-step-body h5{font-size:14px;font-weight:600;color:var(--text-1);letter-spacing:-.005em;margin-bottom:4px;line-height:1.3}
    .modal-step-body p{font-size:13px;color:var(--text-2);line-height:1.55}
    .modal-callout{
      margin-top:24px;padding:16px 18px;background:linear-gradient(135deg,rgba(255,184,0,.06),rgba(255,87,34,.04));border:1px solid rgba(255,184,0,.20);border-radius:var(--r-md);
      font-size:13px;color:var(--text-2);line-height:1.6;
    }
    .modal-callout::before{content:"💡 ";margin-right:4px}
    .modal-links{margin-top:20px;display:flex;flex-direction:column;gap:8px}
    .modal-link{
      display:flex;align-items:center;justify-content:space-between;
      padding:12px 16px;background:var(--text-1);color:var(--obsidian);border-radius:var(--r-md);
      font-size:13px;font-weight:600;letter-spacing:-.005em;text-decoration:none;
      transition:.2s var(--ease);
    }
    .modal-link:hover{background:#fff;transform:translateX(2px)}
    .modal-link::after{content:"↗";font-weight:700}
    /* Print styles */
    @media print{
      body{background:#fff;color:#000}
      .sidebar,.scroll-progress,.action-btn,.live-pill{display:none !important}
      .main{padding:0}
      .app{grid-template-columns:1fr}
      .alert-card,.kpi-card,.account-card,.campaigns-shell,.post-list,.audience-card,.compare-card,.funnel-shell{break-inside:avoid;page-break-inside:avoid}
    }
    .section{margin-bottom:48px}
    .section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;gap:16px;flex-wrap:wrap}
    .section-head h2{font-size:18px;font-weight:700;letter-spacing:-.018em}
    .section-head h2 small{color:var(--text-3);font-weight:500;margin-left:8px;font-size:13px}
    .section-meta{font-size:12px;color:var(--text-3)}
    .mono-label{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--text-3)}
    .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .kpi-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;position:relative;overflow:hidden}
    .kpi-card-spark{position:absolute;right:14px;top:14px;width:90px;height:36px;opacity:.7}
    .kpi-card-label{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:14px}
    .kpi-card-num{font-weight:800;font-size:36px;line-height:1;letter-spacing:-.03em;margin-bottom:10px;font-feature-settings:"tnum"}
    .kpi-card-num small{font-size:.55em;color:var(--text-3);font-weight:500;margin-left:2px}
    .kpi-delta{display:inline-flex;align-items:center;gap:5px;padding:4px 8px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600}
    .kpi-delta-up{background:rgba(52,211,153,.10);color:var(--mint)}
    .kpi-delta-down{background:rgba(244,63,94,.10);color:var(--rose)}
    .kpi-delta-neutral{background:rgba(255,255,255,.05);color:var(--text-3)}
    .kpi-delta-warn{background:rgba(255,184,0,.10);color:var(--accent-2)}
    .kpi-card-foot{font-size:11px;color:var(--text-4);margin-top:8px}
    .account-compare{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .account-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;position:relative}
    .account-card-status{position:absolute;top:18px;right:18px;display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
    .account-card-status.live{background:rgba(52,211,153,.10);color:var(--mint)}
    .account-card-status.dormant{background:rgba(255,255,255,.04);color:var(--text-3)}
    .account-card-status.pending{background:rgba(244,63,94,.10);color:var(--rose)}
    .account-card-name{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-3);margin-bottom:4px;letter-spacing:.04em}
    .account-card-title{font-size:18px;font-weight:700;letter-spacing:-.02em;margin-bottom:18px}
    .account-card-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;padding-top:16px;border-top:1px solid var(--border)}
    .account-stat-label{font-size:11px;color:var(--text-3);margin-bottom:4px;letter-spacing:.04em;text-transform:uppercase;font-weight:500}
    .account-stat-value{font-weight:700;font-size:18px;letter-spacing:-.02em;font-feature-settings:"tnum"}
    .account-stat-value small{color:var(--text-3);font-size:.65em;font-weight:500;margin-left:3px}
    .alerts-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .alert-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:22px;position:relative;overflow:hidden}
    .alert-card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px}
    .alert-card.critical::before{background:var(--rose)}
    .alert-card.warning::before{background:var(--accent-2)}
    .alert-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:12px}
    .alert-tag{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
    .alert-tag.critical{background:rgba(244,63,94,.12);color:var(--rose)}
    .alert-tag.warning{background:rgba(255,184,0,.12);color:var(--accent-2)}
    .alert-time{font-size:11px;color:var(--text-3);font-family:'JetBrains Mono',monospace}
    .alert-title{font-size:15px;font-weight:600;margin-bottom:8px;letter-spacing:-.01em;line-height:1.3}
    .alert-desc{font-size:13px;color:var(--text-2);line-height:1.55;margin-bottom:16px}
    .alert-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding-top:14px;border-top:1px solid var(--border);margin-bottom:16px}
    .alert-stat-label{font-size:10px;color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:3px}
    .alert-stat-val{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:14px}
    .alert-stat-val.mint{color:var(--mint)}.alert-stat-val.rose{color:var(--rose)}.alert-stat-val.warning{color:var(--accent-2)}.alert-stat-val.neutral{color:var(--text-1)}
    .alert-action{display:flex;align-items:center;justify-content:space-between;gap:12px}
    .alert-action-text{font-size:12px;color:var(--text-2)}
    .alert-action-text strong{color:var(--text-1);font-weight:600}
    .campaigns-shell{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden}
    .campaigns-table{width:100%;border-collapse:collapse;font-size:13px}
    .campaigns-table thead{background:rgba(255,255,255,.02)}
    .campaigns-table th{text-align:left;padding:12px 16px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;color:var(--text-3);letter-spacing:.08em;text-transform:uppercase;border-bottom:1px solid var(--border)}
    .campaigns-table th.right{text-align:right}
    .campaigns-table td{padding:14px 16px;border-bottom:1px solid var(--border);vertical-align:middle}
    .campaigns-table td.right{text-align:right;font-family:'JetBrains Mono',monospace;font-feature-settings:"tnum"}
    .campaigns-table tbody tr:last-child td{border-bottom:none}
    .camp-name{font-weight:600;color:var(--text-1);letter-spacing:-.005em}
    .camp-meta{font-size:11px;color:var(--text-3);margin-top:2px;font-family:'JetBrains Mono',monospace}
    .status-dot{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;letter-spacing:.04em}
    .status-dot::before{content:"";width:8px;height:8px;border-radius:50%}
    .status-scale::before{background:var(--mint);box-shadow:0 0 8px rgba(52,211,153,.5)}
    .status-monitor::before{background:var(--accent-2);box-shadow:0 0 8px rgba(255,184,0,.5)}
    .status-stop::before{background:var(--rose);box-shadow:0 0 8px rgba(244,63,94,.5)}
    .status-scale{color:var(--mint)}.status-monitor{color:var(--accent-2)}.status-stop{color:var(--rose)}
    .score-badge{display:inline-flex;align-items:center;gap:8px}
    .score-bar{width:50px;height:6px;background:rgba(255,255,255,.05);border-radius:99px;overflow:hidden}
    .score-bar-fill{height:100%;border-radius:99px}
    .score-num{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:12px;width:28px;text-align:right}
    .compare-grid{display:grid;grid-template-columns:1fr;gap:14px}
    .compare-totals{background:linear-gradient(135deg,rgba(255,87,34,.10) 0%,rgba(255,184,0,.06) 100%);border:1px solid rgba(255,87,34,.20);border-radius:var(--r-lg);padding:24px;margin-bottom:16px}
    .compare-totals-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .compare-total-item h4{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px}
    .compare-total-item .v{font-weight:800;font-size:28px;letter-spacing:-.025em;line-height:1;font-feature-settings:"tnum"}
    .compare-total-item .v small{font-size:.5em;color:var(--text-3);font-weight:600;margin-left:3px}
    .compare-total-item p{font-size:11px;color:var(--text-3);margin-top:4px}
    .compare-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px}
    .compare-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:22px;position:relative;overflow:hidden}
    .compare-card.primary{border-color:rgba(255,87,34,.35);box-shadow:0 0 0 1px rgba(255,87,34,.10)}
    .compare-card.primary::before{content:"PRIMARY";position:absolute;top:14px;right:14px;font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.16em;color:var(--accent);background:rgba(255,87,34,.10);padding:3px 8px;border-radius:99px;border:1px solid rgba(255,87,34,.20)}
    .compare-card-name{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-3);margin-bottom:6px;letter-spacing:.04em}
    .compare-card-title{font-size:16px;font-weight:700;letter-spacing:-.02em;margin-bottom:18px}
    .compare-card-stats{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding-top:14px;border-top:1px solid var(--border)}
    .compare-stat-label{font-size:10px;color:var(--text-3);letter-spacing:.04em;text-transform:uppercase;font-weight:500;margin-bottom:3px}
    .compare-stat-val{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:14px;font-feature-settings:"tnum"}
    .compare-stat-val small{font-size:.7em;color:var(--text-3);font-weight:500;margin-left:2px}
    .compare-card-status{display:inline-flex;align-items:center;gap:6px;padding:3px 9px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px}
    .compare-card-status.active{background:rgba(52,211,153,.10);color:var(--mint);border:1px solid rgba(52,211,153,.20)}
    .compare-card-status.dormant{background:rgba(255,255,255,.04);color:var(--text-3);border:1px solid var(--border)}
    .compare-card-status::before{content:"";width:5px;height:5px;border-radius:50%;background:currentColor}
    .audience-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px}
    .audience-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px}
    .audience-card h3{font-size:14px;font-weight:700;margin-bottom:18px;letter-spacing:-.005em;display:flex;align-items:center;gap:8px}
    .demo-bars{display:flex;flex-direction:column;gap:12px}
    .demo-bar{display:flex;align-items:center;gap:14px}
    .demo-bar-label{width:110px;font-size:12px;color:var(--text-2);font-weight:500;font-family:'JetBrains Mono',monospace}
    .demo-bar-track{flex:1;height:10px;background:rgba(255,255,255,.04);border-radius:99px;overflow:hidden;position:relative}
    .demo-bar-fill{height:100%;border-radius:99px;transition:width .8s var(--ease)}
    .demo-bar-fill.male{background:linear-gradient(90deg,#6366f1,#818cf8)}
    .demo-bar-fill.female{background:linear-gradient(90deg,#FF5722,#FFB800)}
    .demo-bar-val{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;width:80px;text-align:right;font-feature-settings:"tnum"}
    .demo-bar-cpa{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text-3);width:55px;text-align:right;font-weight:600}
    .gender-pill{display:inline-flex;align-items:center;gap:4px;padding:2px 7px;border-radius:99px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
    .gender-pill.male{background:rgba(99,102,241,.10);color:#818cf8;border:1px solid rgba(99,102,241,.25)}
    .gender-pill.female{background:rgba(255,87,34,.10);color:var(--accent);border:1px solid rgba(255,87,34,.25)}
    .placement-list{display:flex;flex-direction:column;gap:8px}
    .placement-row{display:grid;grid-template-columns:1fr auto auto;gap:12px;padding:10px 12px;border-radius:10px;background:rgba(255,255,255,.02);font-size:12px;align-items:center}
    .placement-name{color:var(--text-2);font-family:'JetBrains Mono',monospace;font-size:11px}
    .placement-share{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-3);text-align:right}
    .placement-bar{position:absolute;left:0;top:0;bottom:0;background:rgba(99,102,241,.10);border-radius:10px}
    .placement-row{position:relative;overflow:hidden}
    .placement-row > *{position:relative;z-index:2}
    .country-strip{display:flex;flex-direction:column;gap:10px}
    .country-row{display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
    .country-row:last-child{border-bottom:none}
    .country-flag{font-size:18px}
    .country-name{font-size:13px;font-weight:600}
    .country-stat{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;text-align:right;font-feature-settings:"tnum"}
    .audience-summary{padding:14px 18px;background:linear-gradient(135deg,rgba(255,87,34,.08),rgba(255,184,0,.04));border:1px solid rgba(255,87,34,.18);border-radius:12px;margin-top:18px;font-size:13px;color:var(--text-2);line-height:1.55}
    .audience-summary strong{color:var(--text-1);font-weight:700}
    @media(max-width:900px){.audience-grid{grid-template-columns:1fr}}
    .post-list{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden}
    .post-row{display:grid;grid-template-columns:50px 64px 1fr 90px 90px 90px 100px;align-items:center;gap:14px;padding:16px 20px;border-bottom:1px solid var(--border);transition:.2s var(--ease)}
    .post-row:last-child{border-bottom:none}
    .post-row:hover{background:rgba(255,255,255,.02)}
    .post-rank{font-family:'Instrument Serif',serif;font-style:italic;font-size:22px;color:var(--text-3);font-weight:400;text-align:center}
    .post-rank.top{color:var(--accent-2)}
    .post-thumb{width:48px;height:64px;border-radius:8px;background:linear-gradient(180deg,#1a1a1d,#0a0a0c);border:1px solid var(--border-lit);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--text-4);font-weight:700;overflow:hidden}
    .post-thumb img{width:100%;height:100%;object-fit:cover}
    .post-meta h4{font-weight:600;font-size:14px;margin-bottom:3px;letter-spacing:-.005em}
    .post-meta p{font-size:11px;color:var(--text-3);font-family:'JetBrains Mono',monospace}
    .post-tags{display:flex;gap:5px;margin-top:6px;flex-wrap:wrap}
    .post-tag{padding:2px 7px;border-radius:99px;background:rgba(255,255,255,.04);border:1px solid var(--border);font-size:10px;color:var(--text-3);font-weight:600}
    .post-tag.hidden-winner{background:rgba(52,211,153,.10);border-color:rgba(52,211,153,.25);color:var(--mint)}
    .post-tag.efficient{background:rgba(52,211,153,.06);border-color:rgba(52,211,153,.15);color:var(--mint)}
    .post-tag.scalable{background:rgba(99,102,241,.10);border-color:rgba(99,102,241,.25);color:var(--blue)}
    .post-tag.fatigued{background:rgba(244,63,94,.10);border-color:rgba(244,63,94,.25);color:var(--rose)}
    .post-tag.budget-waste{background:rgba(244,63,94,.10);border-color:rgba(244,63,94,.25);color:var(--rose)}
    .post-tag.no-conversions{background:rgba(255,184,0,.06);border-color:rgba(255,184,0,.20);color:var(--accent-2)}
    .post-tag.underperforming{background:rgba(255,184,0,.06);border-color:rgba(255,184,0,.20);color:var(--accent-2)}
    .post-stat-num{font-family:'JetBrains Mono',monospace;font-feature-settings:"tnum";font-weight:700;font-size:14px}
    .post-stat-label{font-size:9px;color:var(--text-4);letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-top:1px}
    @media(max-width:900px){
      .post-row{grid-template-columns:30px 1fr 80px;gap:10px}
      .post-row .hide-md{display:none}
    }
    .recos-list{display:flex;flex-direction:column;gap:10px}
    .reco-card{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px 22px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:18px}
    .reco-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
    .reco-icon.scale{background:rgba(52,211,153,.10);color:var(--mint)}
    .reco-icon.kill{background:rgba(244,63,94,.10);color:var(--rose)}
    .reco-icon.fatigue{background:rgba(255,184,0,.10);color:var(--accent-2)}
    .reco-icon.duplicate{background:rgba(99,102,241,.10);color:var(--blue)}
    .reco-icon.creative{background:rgba(255,87,34,.10);color:var(--accent)}
    .reco-body h4{font-size:14px;font-weight:600;margin-bottom:4px;letter-spacing:-.005em}
    .reco-body p{font-size:12px;color:var(--text-3);line-height:1.55}
    .reco-priority{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:6px 10px;border-radius:99px;flex-shrink:0}
    .reco-priority.high{background:rgba(244,63,94,.12);color:var(--rose)}
    .reco-priority.med{background:rgba(255,184,0,.12);color:var(--accent-2)}
    .reco-priority.low{background:rgba(255,255,255,.04);color:var(--text-3)}
    .funnel-shell{background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:32px}
    .funnel-bars{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;align-items:end;height:240px;margin-bottom:20px}
    .funnel-step{display:flex;flex-direction:column;align-items:center;gap:10px;height:100%;justify-content:flex-end}
    .funnel-rate{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-3);letter-spacing:.04em}
    .funnel-bar{width:100%;border-radius:8px 8px 0 0;position:relative;display:flex;justify-content:center;padding-top:6px}
    .funnel-bar-val{color:#fff;font-weight:700;font-size:12px;text-shadow:0 1px 2px rgba(0,0,0,.4)}
    .funnel-step-label{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-2);font-weight:600;text-align:center}
    .banner{padding:16px 20px;border-radius:14px;display:flex;align-items:center;gap:14px;font-size:13px;color:var(--text-2);margin-bottom:32px}
    .banner.warn{background:rgba(255,184,0,.06);border:1px solid rgba(255,184,0,.20)}
    .banner-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:18px}
    .banner.warn .banner-icon{background:rgba(255,184,0,.12);color:var(--accent-2)}
    /* ────────── HAMBURGER + DRAWER (mobile sidebar) ────────── */
    .hamburger{
      display:none;width:42px;height:42px;border-radius:10px;
      background:var(--surface-2);border:1px solid var(--border-lit);
      align-items:center;justify-content:center;cursor:pointer;
      color:var(--text-1);transition:.2s var(--ease);flex-shrink:0;
    }
    .hamburger:hover{background:var(--surface-3)}
    .hamburger svg{width:20px;height:20px}
    .sidebar-backdrop{
      display:none;position:fixed;inset:0;z-index:90;background:rgba(0,0,0,.7);
      backdrop-filter:blur(6px);animation:overlayIn .25s var(--ease);
    }
    .sidebar-backdrop.active{display:block}

    @media(max-width:1024px){
      .app{grid-template-columns:1fr}
      .sidebar{
        position:fixed;top:0;left:0;height:100vh;width:280px;z-index:100;
        flex-direction:column;overflow-y:auto;padding:24px 18px;
        transform:translateX(-100%);transition:transform .3s var(--ease);
        box-shadow:0 0 40px rgba(0,0,0,.6);
      }
      .sidebar.open{transform:translateX(0)}
      .sidebar-section-label,.sidebar-footer{display:block}
      .hamburger{display:inline-flex}
      .topbar{align-items:flex-start;gap:12px}
      .topbar-title{flex:1;min-width:0}
      .topbar-title h1{font-size:1.5rem}
      .topbar-actions{flex-wrap:wrap;justify-content:flex-start}
      .kpi-grid{grid-template-columns:repeat(2,1fr);gap:12px}
      .kpi-card{padding:18px}
      .kpi-card-num{font-size:28px}
      .kpi-card-spark{width:60px;height:24px;opacity:.5}
      .account-compare,.alerts-grid,.audience-grid{grid-template-columns:1fr}
      .compare-totals-grid{grid-template-columns:repeat(2,1fr);gap:14px}
      .compare-cards{grid-template-columns:1fr}
      /* Tabla campañas: scroll horizontal con primera col sticky */
      .campaigns-shell{overflow-x:auto;-webkit-overflow-scrolling:touch}
      .campaigns-table{min-width:780px}
      .campaigns-table tbody td:first-child,.campaigns-table thead th:first-child{
        position:sticky;left:0;background:var(--surface-1);z-index:1;box-shadow:2px 0 4px rgba(0,0,0,.2);
      }
      .campaigns-table thead th:first-child{background:rgba(10,10,12,.95)}
      /* Funnel: scroll si no entra */
      .funnel-shell{padding:20px;overflow-x:auto}
      .funnel-bars{min-width:520px;gap:8px;height:200px}
      .funnel-step-label{font-size:9px}
      /* Stepper how-it-works */
      .stepper{grid-template-columns:1fr;gap:14px}
      .stepper::before{display:none}
      /* Urgent cards stack vertical */
      .urgent-shell{padding:20px;margin-bottom:32px}
      .urgent-head h2{font-size:18px}
      .urgent-card{grid-template-columns:1fr;gap:10px;padding:16px}
      .urgent-action-tag{align-self:flex-start;padding:6px 10px;font-size:9px;width:fit-content}
      .urgent-go{align-self:flex-end;font-size:10px;padding:7px 12px}
      .urgent-body h4{font-size:14px}
      /* Post list: scroll si necesita */
      .post-list{overflow-x:auto}
      .post-row{padding:14px 16px}
      /* Modal mobile */
      .modal-overlay{padding:12px}
      .modal{max-height:94vh;border-radius:18px}
      .modal-head{padding:18px 22px 14px;border-radius:18px 18px 0 0}
      .modal-head h3{font-size:17px}
      .modal-body{padding:16px 22px}
      .modal-step{padding:12px 14px;gap:10px}
      .modal-step-num{width:24px;height:24px;font-size:11px}
    }

    @media(max-width:640px){
      :root{--pad:14px}
      .main{padding:14px 14px 90px}
      .topbar{flex-direction:column;align-items:stretch;margin-bottom:24px}
      .topbar-row-1{display:flex;align-items:center;gap:10px}
      .topbar-title h1{font-size:1.25rem;line-height:1.15}
      .topbar-title p{font-size:11px;line-height:1.4;margin-top:4px}
      .topbar-actions{margin-top:0;gap:6px}
      .topbar-actions .pill-group,.topbar-actions .live-pill,.topbar-actions .action-btn{font-size:11px;padding:6px 10px}
      /* KPIs apilados con sparkline al costado */
      .kpi-grid{grid-template-columns:1fr;gap:10px}
      .kpi-card{padding:16px;display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center}
      .kpi-card > .kpi-card-spark{position:static;width:70px;height:32px;grid-row:1 / 4;align-self:center}
      .kpi-card-label{font-size:10px;margin-bottom:6px}
      .kpi-card-num{font-size:24px;margin-bottom:6px}
      .kpi-card-foot{font-size:10px}
      /* Compare totals 2 cols */
      .compare-totals-grid{grid-template-columns:1fr 1fr;gap:10px}
      .compare-totals{padding:16px}
      .compare-total-item .v{font-size:22px}
      .compare-total-item h4{font-size:9px}
      /* Audience bars compactas */
      .demo-bar-label{width:72px;font-size:11px}
      .demo-bar-val{font-size:11px;width:54px}
      .demo-bar-cpa{display:none}
      /* Section spacing */
      .section{margin-bottom:32px}
      .section-head{margin-bottom:14px;flex-direction:column;align-items:flex-start}
      .section-head h2{font-size:16px}
      .section-head h2 small{display:block;margin:4px 0 0;font-size:11px}
      .section-meta{font-size:10px}
      /* Card adjustments */
      .audience-card{padding:16px}
      .alert-card{padding:14px}
      .alert-title{font-size:14px}
      .alert-desc{font-size:12px}
      .alert-stats{grid-template-columns:1fr 1fr 1fr;gap:8px;padding:10px 0;margin-bottom:12px}
      .alert-stat-val{font-size:13px}
      .alert-stat-label{font-size:8px}
      .alert-action-text{font-size:11px}
      /* Reco cards */
      .reco-card{grid-template-columns:auto 1fr;gap:12px;padding:14px 16px}
      .reco-icon{width:32px;height:32px;font-size:15px}
      .reco-priority{grid-column:1 / -1;justify-self:start;margin-top:6px;font-size:9px;padding:4px 8px}
      .reco-body h4{font-size:13px}
      .reco-body p{font-size:11px}
      /* Funnel ultra compacto */
      .funnel-bars{height:180px;min-width:480px}
      .funnel-shell > div:last-child{flex-direction:column;gap:8px;align-items:flex-start}
      /* Story / pricing-mega */
      .story-quote{font-size:1.4rem}
      .pricing-mega-num{font-size:5rem}
      /* Account compare */
      .account-card{padding:18px}
      .account-card-stats{grid-template-columns:1fr 1fr;gap:10px}
      /* Footer */
      .footer{padding:30px 16px}
    }

    @media(max-width:380px){
      .topbar-title h1{font-size:1.1rem}
      .kpi-card-num{font-size:22px}
      .urgent-action-tag{font-size:8px;padding:5px 8px}
      .modal-body{padding:14px 18px}
      .modal-step{grid-template-columns:24px 1fr;gap:10px;padding:10px 12px}
      .modal-step-body h5{font-size:13px}
      .modal-step-body p{font-size:12px}
    }
  </style>
</head>
<body>
  <div class="scroll-progress" id="scrollProgress"></div>
  <div class="toast" id="toast"></div>
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
  <div class="app">

    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-mark">S</div>
        <div><div>Serene · AI</div><small>COMMAND CENTER</small></div>
      </div>
      <div class="sidebar-section">
        <span class="sidebar-section-label">Secciones</span>
        {% if urgent_actions %}<a class="sidebar-link" href="#urgent" data-target="urgent" style="color:var(--rose);font-weight:700">🚨 Urgentes <span class="sidebar-link-badge">{{ urgent_actions|length }}</span></a>{% endif %}
        <a class="sidebar-link active" href="#executive" data-target="executive">📊 Executive</a>
        {% if shopify %}<a class="sidebar-link" href="#shopify" data-target="shopify">🛍 Shopify <span class="sidebar-link-badge" style="background:var(--mint);color:#000">{{ "%.1fx"|format(shopify.real_roas) if shopify.real_roas else "—" }}</span></a>{% endif %}
        <a class="sidebar-link" href="#funnel" data-target="funnel">🔻 Funnel</a>
        <a class="sidebar-link" href="#alerts" data-target="alerts">⚠ Insights <span class="sidebar-link-badge">{{ stats.insights_critical + stats.insights_warning }}</span></a>
        {% if smart_opportunities %}<a class="sidebar-link" href="#opportunities" data-target="opportunities">💡 Próximas publicaciones <span class="sidebar-link-badge" style="background:var(--accent);color:#000">{{ smart_opportunities|length }}</span></a>{% endif %}
        {% if model_stats %}<a class="sidebar-link" href="#model" data-target="model">🧠 Modelo Predictivo <span class="sidebar-link-badge" style="background:var(--blue);color:#fff">{{ model_stats.dataset_size }}</span></a>{% endif %}
        <a class="sidebar-link" href="#campaigns" data-target="campaigns">📈 Campaigns <span class="sidebar-link-badge">{{ stats.campaigns_total }}</span></a>
        {% if activity and activity.total_human %}<a class="sidebar-link" href="#activity" data-target="activity">🕒 Activity <span class="sidebar-link-badge" style="background:var(--blue);color:#fff">{{ activity.total_human }}</span></a>{% endif %}
        {% if post_ids %}<a class="sidebar-link" href="#post-ids" data-target="post-ids">🎬 Post IDs <span class="sidebar-link-badge" style="background:var(--accent-2);color:#000">{{ stats.post_ids_with_purchases }}</span></a>{% endif %}
        {% if audience and audience.age_gender %}<a class="sidebar-link" href="#audience" data-target="audience">👥 Audience</a>{% endif %}
        {% if recommendations %}<a class="sidebar-link" href="#recommendations" data-target="recommendations">🧠 Recos AI <span class="sidebar-link-badge" style="background:var(--mint);color:#000">{{ recommendations|length }}</span></a>{% endif %}
      </div>
      <div class="sidebar-footer">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
          <span class="live-pill warn" style="font-size:10px;padding:4px 10px">{{ account.status_label or 'snapshot' }}</span>
        </div>
        v3.0 · Auto-generated<br>{{ generated_at_short }}
      </div>
    </aside>

    <main class="main">

      <!-- Top bar -->
      <div class="topbar">
        <button class="hamburger" id="btn-menu" aria-label="Menú">
          <svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="topbar-title">
          <h1>Performance <span class="serif">command</span> center</h1>
          <p><strong style="color:var(--text-1);font-weight:600">{{ account.name }}</strong> · {{ date_range.since }} → {{ date_range.until }} · <span data-tip="Última generación del dashboard. El cron corre cada día 7am.">Generado {{ generated_at }}</span></p>
        </div>
        <div class="topbar-actions">
          {% if shopify %}
          <span style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,rgba(52,211,153,.12),rgba(255,184,0,.06));border:1px solid rgba(52,211,153,.30);padding:6px 12px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;color:var(--mint)" data-tip="Revenue real Shopify · ROAS = revenue / Meta spend">
            💰 ${{ (shopify.revenue / 1_000_000)|round(1) }}M
            <span style="color:var(--text-3);font-weight:500">·</span>
            <span style="color:{{ '#34d399' if shopify.real_roas and shopify.real_roas >= 2 else '#f43f5e' if shopify.real_roas and shopify.real_roas < 1 else 'var(--text-1)' }}">{{ "%.1fx"|format(shopify.real_roas) if shopify.real_roas else "—" }}</span>
          </span>
          {% endif %}
          {% if activity and activity.total_human %}
          <span style="display:inline-flex;align-items:center;gap:6px;background:rgba(99,102,241,.10);border:1px solid rgba(99,102,241,.25);padding:6px 12px;border-radius:99px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;color:var(--blue)" data-tip="Cambios humanos cross-platform en el período">
            🕒 {{ activity.total_human }}
          </span>
          {% endif %}
          <span class="live-pill warn" data-tip="Data extraída via Meta Graph API v22.0 directamente">{{ data_source_label }}</span>
          <button class="action-btn" id="btn-regen" data-tip="Dispara GitHub Action para regenerar (requiere PAT)">
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 12a8 8 0 0114-5.3M20 4v5h-5M20 12a8 8 0 01-14 5.3M4 20v-5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Refresh
          </button>
          <button class="action-btn" id="btn-print" data-tip="Imprimir o exportar como PDF">
            <svg viewBox="0 0 24 24" fill="none"><path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Print
          </button>
        </div>
      </div>

      <!-- Banner contextual -->
      {% if account.status == 'dormant' %}
      <div class="banner warn">
        <div class="banner-icon">⚠</div>
        <div style="flex:1">
          <strong style="color:var(--text-1);font-weight:600">Vista preview · {{ account.status_label|capitalize }}</strong>
          <div style="color:var(--text-3);font-size:12px;margin-top:2px">Datos reales extraídos vía Meta API. Cuando el script tenga acceso a producción, este dashboard mostrará M4 en vivo con auto-refresh diario.</div>
        </div>
      </div>
      {% endif %}

      <!-- ⚠ URGENT ACTIONS — kill list / fix list -->
      {% if urgent_actions %}
      <section class="urgent-shell" id="urgent">
        <div class="urgent-head">
          <h2>
            <span class="siren">🚨</span>
            Acciones urgentes
            <span style="font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:var(--text-2);font-size:.7em;margin-left:6px">— hay que apagar</span>
          </h2>
          <span class="urgent-count">{{ urgent_actions|length }} acción{{ 'es' if urgent_actions|length != 1 else '' }} requerida{{ 's' if urgent_actions|length != 1 else '' }}</span>
        </div>

        <div class="urgent-list">
          {% for a in urgent_actions %}
          <div class="urgent-card {{ a.severity }}" data-urgent-idx="{{ loop.index0 }}">
            <div class="urgent-action-tag {{ a.severity }}">{{ a.action }}</div>
            <div class="urgent-body">
              <h4>{{ a.target_name }}</h4>
              <div class="reason">{{ a.reason }}</div>
              <div class="impact">{{ a.impact }}</div>
            </div>
            <span class="urgent-go">Ver detalle →</span>
          </div>
          {% endfor %}
        </div>
      </section>
      {% else %}
      <section class="urgent-shell" id="urgent" style="background:rgba(52,211,153,.06);border-color:rgba(52,211,153,.25)">
        <div class="urgent-empty">
          Cuenta saludable — no hay acciones urgentes detectadas
        </div>
      </section>
      {% endif %}

      <!-- KPI Hero -->
      <section class="section" id="executive">
        <div class="section-head">
          <h2>Resumen ejecutivo <small>· {{ date_range.days }} días</small></h2>
          <span class="section-meta"><code>{{ account.id }}</code> · {{ account.currency }}</span>
        </div>
        <div class="kpi-grid">
          <div class="kpi-card">
            <svg class="kpi-card-spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none">
              <path d="M0,30 L10,28 L20,24 L30,18 L40,14 L50,10 L60,8 L70,12 L80,16 L90,22" stroke="#FF5722" stroke-width="2" stroke-linecap="round" fill="none"/>
              <path d="M0,30 L10,28 L20,24 L30,18 L40,14 L50,10 L60,8 L70,12 L80,16 L90,22 L90,36 L0,36 Z" fill="url(#g1)"/>
              <defs><linearGradient id="g1" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#FF5722" stop-opacity="0.3"/><stop offset="1" stop-color="#FF5722" stop-opacity="0"/></linearGradient></defs>
            </svg>
            <div class="kpi-card-label">SPEND TOTAL</div>
            <div class="kpi-card-num">{{ summary.spend|fmt }}<small> {{ account.currency }}</small></div>
            <span class="kpi-delta kpi-delta-neutral">≈ ${{ summary.spend_usd|fmt }} USD</span>
            <div class="kpi-card-foot">{{ (summary.spend / date_range.days)|fmt }}/día promedio</div>
          </div>
          <div class="kpi-card">
            <svg class="kpi-card-spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none">
              <path d="M0,30 L10,28 L20,22 L30,16 L40,12 L50,10 L60,8 L70,10 L80,14 L90,18" stroke="#34d399" stroke-width="2" stroke-linecap="round" fill="none"/>
              <defs><linearGradient id="g2" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#34d399" stop-opacity="0.3"/><stop offset="1" stop-color="#34d399" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,30 L10,28 L20,22 L30,16 L40,12 L50,10 L60,8 L70,10 L80,14 L90,18 L90,36 L0,36 Z" fill="url(#g2)"/>
            </svg>
            <div class="kpi-card-label">PURCHASES</div>
            <div class="kpi-card-num">{{ summary.purchases }}</div>
            <span class="kpi-delta kpi-delta-up">{{ funnel.click_to_purchase|round(2) }}% click→buy</span>
            <div class="kpi-card-foot">CR funnel completo</div>
          </div>
          <div class="kpi-card">
            <svg class="kpi-card-spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none">
              <path d="M0,12 L10,14 L20,18 L30,22 L40,26 L50,28 L60,30 L70,28 L80,26 L90,24" stroke="#FFB800" stroke-width="2" stroke-linecap="round" fill="none"/>
              <defs><linearGradient id="g3" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#FFB800" stop-opacity="0.3"/><stop offset="1" stop-color="#FFB800" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,12 L10,14 L20,18 L30,22 L40,26 L50,28 L60,30 L70,28 L80,26 L90,24 L90,36 L0,36 Z" fill="url(#g3)"/>
            </svg>
            <div class="kpi-card-label">CPA</div>
            <div class="kpi-card-num">{{ summary.cpa|fmt }}<small></small></div>
            <span class="kpi-delta kpi-delta-neutral">{{ account.currency }} por compra</span>
            <div class="kpi-card-foot">Best: {{ campaigns_best_cpa|fmt }} · Worst: {{ campaigns_worst_cpa|fmt }}</div>
          </div>
          <div class="kpi-card">
            <svg class="kpi-card-spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none">
              <path d="M0,28 L10,26 L20,24 L30,22 L40,18 L50,14 L60,12 L70,10 L80,8 L90,6" stroke="#f43f5e" stroke-width="2" stroke-linecap="round" fill="none"/>
              <defs><linearGradient id="g4" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#f43f5e" stop-opacity="0.3"/><stop offset="1" stop-color="#f43f5e" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,28 L10,26 L20,24 L30,22 L40,18 L50,14 L60,12 L70,10 L80,8 L90,6 L90,36 L0,36 Z" fill="url(#g4)"/>
            </svg>
            <div class="kpi-card-label">FREQUENCY</div>
            <div class="kpi-card-num">{{ summary.frequency|round(2) }}<small>x</small></div>
            {% if summary.frequency > 4.0 %}<span class="kpi-delta kpi-delta-down">⚠ crítica</span>
            {% elif summary.frequency > 2.5 %}<span class="kpi-delta kpi-delta-warn">⚠ saturación</span>
            {% else %}<span class="kpi-delta kpi-delta-up">saludable</span>{% endif %}
            <div class="kpi-card-foot">Reach {{ summary.reach|fmt }} · target freq &lt; 2.5</div>
          </div>
        </div>
      </section>

      <!-- Multi-Account Comparison (only when combined snapshot) -->
      {% if comparison and comparison.accounts|length > 1 %}
      <section class="section">
        <div class="section-head">
          <h2>Multi-Account Comparison <small>· {{ comparison.combined.accounts_count }} cuentas</small></h2>
          <span class="section-meta">{{ comparison.combined.active_accounts }} active · USD blended</span>
        </div>

        <!-- Combined totals -->
        <div class="compare-totals">
          <div class="compare-totals-grid">
            <div class="compare-total-item">
              <h4>Spend Combined</h4>
              <div class="v"><small>$</small>{{ (comparison.combined.total_spend_usd / 1000)|round(1) }}<small>K USD</small></div>
              <p>Suma de {{ comparison.combined.accounts_count }} cuentas</p>
            </div>
            <div class="compare-total-item">
              <h4>Purchases</h4>
              <div class="v">{{ comparison.combined.total_purchases }}</div>
              <p>Total cross-account</p>
            </div>
            <div class="compare-total-item">
              <h4>Blended CPA</h4>
              <div class="v"><small>$</small>{{ comparison.combined.blended_cpa_usd|round(2) if comparison.combined.blended_cpa_usd else '—' }}<small> USD</small></div>
              <p>Promedio ponderado</p>
            </div>
            <div class="compare-total-item">
              <h4>Blended Freq</h4>
              <div class="v">{{ comparison.combined.weighted_frequency|round(2) }}<small>x</small></div>
              <p>Por impressions</p>
            </div>
          </div>
        </div>

        <!-- Per-account cards -->
        <div class="compare-cards">
          {% for acc in comparison.accounts %}
          <div class="compare-card{% if acc.id == comparison.primary_id %} primary{% endif %}">
            <span class="compare-card-status {{ 'active' if acc.active_campaigns > 0 else 'dormant' }}">{{ acc.status }}</span>
            <div class="compare-card-name">{{ acc.id }} · {{ acc.currency }}</div>
            <div class="compare-card-title">{{ acc.name }}</div>
            <div class="compare-card-stats">
              <div>
                <div class="compare-stat-label">Spend</div>
                <div class="compare-stat-val">{{ acc.spend|fmt }}<small> {{ acc.currency }}</small></div>
              </div>
              <div>
                <div class="compare-stat-label">Spend USD</div>
                <div class="compare-stat-val">${{ acc.spend_usd|fmt }}</div>
              </div>
              <div>
                <div class="compare-stat-label">Purchases</div>
                <div class="compare-stat-val">{{ acc.purchases }}</div>
              </div>
              <div>
                <div class="compare-stat-label">CPA</div>
                <div class="compare-stat-val">{{ acc.cpa|fmt if acc.cpa else '—' }}<small>{% if acc.cpa %} {{ acc.currency }}{% endif %}</small></div>
              </div>
              <div>
                <div class="compare-stat-label">Frequency</div>
                <div class="compare-stat-val">{{ acc.frequency|round(2) }}<small>x</small></div>
              </div>
              <div>
                <div class="compare-stat-label">CTR</div>
                <div class="compare-stat-val">{{ acc.ctr|round(2) }}<small>%</small></div>
              </div>
              <div>
                <div class="compare-stat-label">Campañas</div>
                <div class="compare-stat-val">{{ acc.active_campaigns }}<small>/{{ acc.total_campaigns }}</small></div>
              </div>
              <div>
                <div class="compare-stat-label">Periodo</div>
                <div class="compare-stat-val" style="font-size:11px">{{ acc.date_range.since }} → {{ acc.date_range.until }}</div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- Shopify · Revenue + Cohorts -->
      {% if shopify %}
      <section class="section" id="shopify">
        <div class="section-head">
          <h2>🛍 Shopify <span class="serif">·</span> Revenue real</h2>
          <span class="section-meta">{{ shopify.orders_count }} órdenes · ROAS real {{ "%.2f"|format(shopify.real_roas) if shopify.real_roas else "—" }}x</span>
        </div>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px">
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">Revenue 7d</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">${{ (shopify.revenue / 1_000_000)|round(1) }}M <span style="font-size:11px;color:var(--text-3);font-weight:500">{{ shopify.currency }}</span></div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">{{ shopify.orders_count }} órdenes</div>
          </div>
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">AOV</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">${{ (shopify.aov / 1_000)|round(0)|int }}K</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">Discount rate {{ shopify.discount_rate|round(0)|int }}%</div>
          </div>
          <div style="background:linear-gradient(135deg,rgba(255,87,34,.10),rgba(255,184,0,.05));border:1px solid rgba(255,87,34,.30);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:8px">ROAS Real</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em;color:{{ '#34d399' if shopify.real_roas and shopify.real_roas >= 2 else '#f43f5e' if shopify.real_roas and shopify.real_roas < 1 else 'var(--text-1)' }}">{{ "%.2f"|format(shopify.real_roas) if shopify.real_roas else "—" }}x</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">Revenue / Meta spend</div>
          </div>
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">New vs Returning</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">{{ shopify.cohorts.new_pct|round(0)|int }}% <span style="font-size:13px;color:var(--text-3);font-weight:500">/ {{ shopify.cohorts.returning_pct|round(0)|int }}%</span></div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">{{ shopify.cohorts.new }} nuevos · {{ shopify.cohorts.returning }} repiten</div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:18px;margin-bottom:18px">
          <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px">Top SKUs <small style="color:var(--text-3);font-weight:500;font-size:11px">· por unidades</small></h3>
            <div style="display:flex;flex-direction:column;gap:8px">
              {% for s in shopify.top_skus[:8] %}
              <div style="display:grid;grid-template-columns:80px 1fr auto auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
                <code style="color:var(--accent);font-weight:700">{{ s.sku }}</code>
                <span style="color:var(--text-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{{ s.title }}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--text-1)">{{ s.units }}u</span>
                <span style="font-family:'JetBrains Mono',monospace;color:var(--text-3);font-size:11px">${{ (s.revenue / 1_000_000)|round(1) }}M</span>
              </div>
              {% endfor %}
            </div>
          </div>

          <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px">🏙 Top Ciudades</h3>
            <div style="display:flex;flex-direction:column;gap:6px">
              {% for c in shopify.top_cities[:8] %}
              <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
                <span style="color:var(--text-2)">{{ c.city }}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700">{{ c.orders }}</span>
                <span style="font-family:'JetBrains Mono',monospace;color:var(--text-3);font-size:11px">{{ c.share|round(0)|int }}%</span>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div style="background:rgba(244,63,94,.06);border:1px solid rgba(244,63,94,.25);border-radius:12px;padding:14px 18px">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <span style="font-size:16px">⚠️</span>
              <h4 style="font-size:13px;font-weight:700;color:var(--rose)">Carritos abandonados</h4>
            </div>
            <div style="font-size:20px;font-weight:800;letter-spacing:-.02em">${{ (shopify.abandoned.value_lost / 1_000_000)|round(0)|int }}M <span style="font-size:11px;color:var(--text-3);font-weight:500">{{ shopify.currency }} perdidos</span></div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">{{ shopify.abandoned.count }} carritos · {{ shopify.abandoned.value_lost_pct_revenue|round(0)|int }}% del revenue</div>
          </div>
          <div style="background:rgba(255,184,0,.06);border:1px solid rgba(255,184,0,.25);border-radius:12px;padding:14px 18px">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <span style="font-size:16px">📦</span>
              <h4 style="font-size:13px;font-weight:700;color:var(--accent-2)">Inventory Tendencia</h4>
            </div>
            <div style="font-size:20px;font-weight:800;letter-spacing:-.02em">{{ shopify.tendencia.no_tracking }}/{{ shopify.tendencia.total }} <span style="font-size:11px;color:var(--text-3);font-weight:500">sin tracking</span></div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">{{ shopify.tendencia.in_stock }} con stock · {{ shopify.tendencia.out_of_stock }} agotados</div>
          </div>
        </div>
      </section>
      {% endif %}

      <!-- Funnel -->
      <section class="section" id="funnel">
        <div class="section-head">
          <h2>Funnel de conversión</h2>
          <span class="section-meta">5 etapas · pixel events</span>
        </div>
        <div class="funnel-shell">
          <div class="funnel-bars">
            {% set steps = [
              ('IMPRESSIONS', funnel.impressions, '100%', '#FF5722', 100),
              ('CLICKS', funnel.clicks, (funnel.ctr_rate|round(2)|string ~ '%'), '#FF7B54', 18),
              ('LANDING VIEW', funnel.lpv, (funnel.click_to_lpv|round(1)|string ~ '%'), '#FFB800', 14),
              ('ADD TO CART', funnel.atc, (funnel.lpv_to_atc|round(1)|string ~ '%'), '#34d399', 11),
              ('CHECKOUT', funnel.ic, (funnel.atc_to_ic|round(1)|string ~ '%'), '#10b981', 6),
              ('PURCHASES', funnel.purchases, (funnel.ic_to_purchase|round(1)|string ~ '%'), '#6366f1', 4)
            ] %}
            {% for label, val, rate, color, height in steps %}
            <div class="funnel-step">
              <div class="funnel-rate">{{ rate }}</div>
              <div class="funnel-bar" style="background:linear-gradient(180deg,{{ color }},{{ color }}99);height:{{ height }}%">
                <span class="funnel-bar-val" style="{% if color in ['#FFB800','#34d399'] %}color:#0a0a0a{% endif %}">{{ val|fmt }}</span>
              </div>
              <div class="funnel-step-label">{{ label }}</div>
            </div>
            {% endfor %}
          </div>
          <div style="display:flex;justify-content:space-between;padding-top:18px;border-top:1px solid var(--border);font-size:12px;color:var(--text-3);flex-wrap:wrap;gap:14px">
            <span>Funnel completo · <strong style="color:var(--text-1)">Click → Purchase: {{ funnel.click_to_purchase|round(2) }}%</strong></span>
            {% set max_drop = funnel|leak_step %}
            {% if max_drop %}<span>Mayor leak: <strong style="color:var(--rose)">{{ max_drop.name }} ({{ max_drop.drop }}% drop)</strong></span>{% endif %}
          </div>
        </div>
      </section>

      <!-- Insights -->
      {% if insights %}
      <section class="section" id="alerts">
        <div class="section-head">
          <h2>Insights AI <small>· {{ insights|length }} detectados</small></h2>
          <span class="section-meta">Análisis automático · pattern recognition</span>
        </div>
        <div class="alerts-grid">
          {% for ins in insights %}
          <article class="alert-card {{ ins.severity }}">
            <div class="alert-head">
              <span class="alert-tag {{ ins.severity }}">● {{ ins.severity|upper }} · {{ ins.type|replace('_',' ') }}</span>
              <span class="alert-time">detectado</span>
            </div>
            <h3 class="alert-title">{{ ins.title }}</h3>
            <p class="alert-desc">{{ ins.description }}</p>
            <div class="alert-stats">
              {% for stat in ins.stats %}
              <div>
                <div class="alert-stat-label">{{ stat.label }}</div>
                <div class="alert-stat-val {{ stat.color }}">{{ stat.value }}</div>
              </div>
              {% endfor %}
            </div>
            <div class="alert-action">
              <div class="alert-action-text"><strong>Acción:</strong> {{ ins.action }}</div>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- Smart Opportunities · Próximas publicaciones recomendadas -->
      {% if smart_opportunities and smart_opportunities|length > 0 %}
      <section class="section" id="opportunities">
        <div class="section-head">
          <h2>💡 Próximas publicaciones <small>· {{ smart_opportunities|length }} oportunidades · gap analysis basada en data</small></h2>
          <span class="section-meta">algorítmico · auto-detectado</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:14px">
          {% for o in smart_opportunities %}
          <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:18px;position:relative;overflow:hidden">
            <div style="position:absolute;top:14px;right:14px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.05em;background:linear-gradient(135deg,#34d399,#10b981);color:#000;padding:3px 8px;border-radius:6px;font-weight:700">{{ o.confidence }}%</div>
            <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:12px">
              <span style="font-size:24px;line-height:1">{{ o.emoji }}</span>
              <div style="flex:1">
                <h3 style="font-size:14px;font-weight:700;letter-spacing:-.01em;line-height:1.35;padding-right:50px">{{ o.hook }}</h3>
                <div style="display:flex;gap:6px;margin-top:6px;flex-wrap:wrap">
                  <span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.05em;padding:2px 7px;border-radius:4px;background:rgba(255,87,34,.14);color:var(--accent)">{{ o.funnel|upper }}</span>
                  <span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.05em;padding:2px 7px;border-radius:4px;background:rgba(99,102,241,.14);color:var(--blue)">{{ o.avatar|upper }}</span>
                  {% if o.sku %}<span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.05em;padding:2px 7px;border-radius:4px;background:var(--surface-3);color:var(--text-2)">{{ o.sku }}</span>{% endif %}
                </div>
              </div>
            </div>
            <div style="font-size:12px;color:var(--text-2);line-height:1.55;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--border)">
              <strong style="color:var(--text-3);font-weight:600;text-transform:uppercase;font-size:10px;letter-spacing:.08em">Why</strong><br>
              {{ o.why }}
            </div>
            <div style="font-size:12px;color:var(--text-1);line-height:1.55">
              <strong style="color:var(--mint);font-weight:600;text-transform:uppercase;font-size:10px;letter-spacing:.08em">Action</strong><br>
              {{ o.action }}
            </div>
          </div>
          {% endfor %}
        </div>
        <p style="text-align:center;font-size:11px;color:var(--text-4);margin-top:18px">
          Recomendaciones derivadas de gap analysis sobre Meta winners + Shopify top SKUs. Fase 2 (futuro): trends externos + competitor scraping + LLM synthesis.
        </p>
      </section>
      {% endif %}

      <!-- Modelo Predictivo · Duración de campañas -->
      {% if model_stats %}
      <section class="section" id="model">
        <div class="section-head">
          <h2>🧠 Modelo Predictivo <small>· duración campañas · Nivel 2+3 (heurística + comparable past)</small></h2>
          <span class="section-meta">{{ model_stats.dataset_size }} campañas históricas · last {{ model_stats.days_back }}d</span>
        </div>

        <!-- 4 KPI tiles -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px">
          <div style="background:linear-gradient(135deg,rgba(99,102,241,.12),rgba(99,102,241,.04));border:1px solid rgba(99,102,241,.30);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--blue);margin-bottom:8px">Dataset</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">{{ model_stats.dataset_size }} <span style="font-size:11px;color:var(--text-3);font-weight:500">campañas</span></div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">paused last {{ model_stats.days_back }}d</div>
          </div>
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">Mediana duración</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">{{ model_stats.median }}d</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">Mean {{ model_stats.mean }}d · max {{ model_stats.max }}d</div>
          </div>
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">Rango P25-P75</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">{{ model_stats.p25 }}–{{ model_stats.p75 }}d</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">50% campañas en este rango</div>
          </div>
          <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">P90 (cola larga)</div>
            <div style="font-size:22px;font-weight:800;letter-spacing:-.02em">{{ model_stats.p90 }}d</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:4px">10% campañas pasan este límite</div>
          </div>
        </div>

        <!-- Distribución gráfica -->
        <div style="display:grid;grid-template-columns:1.3fr 1fr;gap:18px;margin-bottom:18px">
          <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px">📊 Distribución duración <small style="color:var(--text-3);font-weight:500;font-size:11px">· cuánto duran tus campañas antes de pausarse</small></h3>
            {% set max_pct = model_stats.distribution|map(attribute='pct')|max %}
            <div style="display:flex;flex-direction:column;gap:8px">
              {% for d in model_stats.distribution %}
              <div style="display:grid;grid-template-columns:70px 1fr 60px;gap:12px;align-items:center;font-size:12px">
                <code style="color:var(--text-3);font-weight:600">{{ d.label }}</code>
                <div style="background:var(--surface-3);height:18px;border-radius:6px;overflow:hidden;position:relative">
                  <div style="background:linear-gradient(90deg,#6366f1,#FF5722);height:100%;width:{{ (d.pct / max_pct * 100)|round }}%;border-radius:6px"></div>
                </div>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700;text-align:right">{{ d.count }} <span style="color:var(--text-3);font-weight:500">({{ d.pct }}%)</span></span>
              </div>
              {% endfor %}
            </div>
          </div>

          <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:14px">📋 Por objective</h3>
            <div style="display:flex;flex-direction:column;gap:6px">
              {% for o in model_stats.by_objective %}
              <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
                <code style="color:var(--accent);font-weight:600">{{ o.objective|replace('OUTCOME_','') }}</code>
                <span style="font-family:'JetBrains Mono',monospace;color:var(--text-3)">n={{ o.count }}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700">median {{ o.median }}d</span>
              </div>
              {% endfor %}
            </div>
            <p style="font-size:11px;color:var(--text-4);margin-top:12px;line-height:1.55">
              Cuando una campaña activa tiene mismo objective + budget similar, se usa este median como baseline de predicción.
            </p>
          </div>
        </div>

        <!-- Active campaigns: top en riesgo + top saludables -->
        {% set active_camps = campaigns|selectattr('duration.status', 'in', ['warming','fatigued','burnt'])|list %}
        {% set safe_camps = campaigns|selectattr('duration.status', 'in', ['fresh','healthy'])|list %}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div style="background:rgba(244,63,94,.05);border:1px solid rgba(244,63,94,.25);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;color:var(--rose);margin-bottom:14px">🔥 En riesgo · pausar pronto</h3>
            {% if active_camps %}
            <div style="display:flex;flex-direction:column;gap:6px">
              {% for c in active_camps|sort(attribute='duration.days_remaining')|list %}
              {% if loop.index <= 6 %}
              <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px">
                <div style="overflow:hidden">
                  <div style="color:var(--text-1);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ c.name|truncate_smart(42) }}</div>
                  <div style="color:var(--text-3);font-size:11px;margin-top:2px">freq {{ c.duration.freq_now }} · edad {{ c.duration.age_days or '?' }}d{% if c.duration.comparable_count %} · {{ c.duration.comparable_count }} sim{% endif %}</div>
                </div>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700;color:{% if c.duration.status == 'burnt' %}var(--rose){% elif c.duration.status == 'fatigued' %}var(--accent){% else %}var(--accent-2){% endif %};font-size:14px">{{ c.duration.days_remaining }}d</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:9px;background:{% if c.duration.status == 'burnt' %}var(--rose){% elif c.duration.status == 'fatigued' %}var(--accent){% else %}var(--accent-2){% endif %};color:#000;padding:2px 6px;border-radius:4px;font-weight:700">{{ c.duration.status|upper }}</span>
              </div>
              {% endif %}
              {% endfor %}
            </div>
            {% else %}
            <p style="color:var(--text-3);font-size:12px;text-align:center;padding:18px 0">✨ Ninguna activa fatigada · todo sano</p>
            {% endif %}
          </div>

          <div style="background:rgba(52,211,153,.04);border:1px solid rgba(52,211,153,.20);border-radius:14px;padding:18px">
            <h3 style="font-size:14px;font-weight:700;color:var(--mint);margin-bottom:14px">✅ Saludables · margen amplio</h3>
            {% if safe_camps %}
            <div style="display:flex;flex-direction:column;gap:6px">
              {% for c in safe_camps|sort(attribute='duration.days_remaining', reverse=True)|list %}
              {% if loop.index <= 6 %}
              <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px">
                <div style="overflow:hidden">
                  <div style="color:var(--text-1);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ c.name|truncate_smart(42) }}</div>
                  <div style="color:var(--text-3);font-size:11px;margin-top:2px">freq {{ c.duration.freq_now }} · edad {{ c.duration.age_days or '?' }}d{% if c.duration.comparable_count %} · {{ c.duration.comparable_count }} sim{% endif %}</div>
                </div>
                <span style="font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--mint);font-size:14px">{{ c.duration.days_remaining }}d</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:9px;background:var(--mint);color:#000;padding:2px 6px;border-radius:4px;font-weight:700">{{ c.duration.status|upper }}</span>
              </div>
              {% endif %}
              {% endfor %}
            </div>
            {% else %}
            <p style="color:var(--text-3);font-size:12px;text-align:center;padding:18px 0">Ninguna fresh hoy</p>
            {% endif %}
          </div>
        </div>

        <!-- Explicación cómo funciona -->
        <details style="background:var(--surface-1);border:1px solid var(--border);border-radius:14px;padding:14px 18px">
          <summary style="cursor:pointer;font-size:13px;font-weight:600;color:var(--text-2);user-select:none">📖 Cómo funciona el modelo · features + pesos</summary>
          <div style="margin-top:14px;font-size:12px;color:var(--text-2);line-height:1.65">
            <p style="margin-bottom:12px"><strong style="color:var(--text-1)">Inputs (qué mira):</strong></p>
            <ul style="padding-left:20px;margin-bottom:14px">
              <li><strong style="color:var(--accent)">Frequency actual</strong> + tasa de crecimiento por día (Nivel 2)</li>
              <li><strong style="color:var(--accent)">Edad de la campaña</strong> (start_time → hoy)</li>
              <li><strong style="color:var(--accent)">CPA actual vs promedio cuenta</strong> — si está 1.5x sobre, resta 3 días</li>
              <li><strong style="color:var(--accent)">Similitud con campañas pasadas</strong> de tu cuenta (Nivel 3, peso mayor)</li>
            </ul>

            <p style="margin-bottom:12px"><strong style="color:var(--text-1)">Cómo encuentra similares (top-8 matching):</strong></p>
            <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px">
              <div style="background:var(--surface-2);padding:10px;border-radius:8px;text-align:center"><div style="font-size:18px;font-weight:800;color:var(--blue)">40%</div><div style="font-size:10px;color:var(--text-3);margin-top:2px">Mismo objective</div></div>
              <div style="background:var(--surface-2);padding:10px;border-radius:8px;text-align:center"><div style="font-size:18px;font-weight:800;color:var(--blue)">20%</div><div style="font-size:10px;color:var(--text-3);margin-top:2px">Tokens del nombre</div></div>
              <div style="background:var(--surface-2);padding:10px;border-radius:8px;text-align:center"><div style="font-size:18px;font-weight:800;color:var(--blue)">15%</div><div style="font-size:10px;color:var(--text-3);margin-top:2px">Bid strategy</div></div>
              <div style="background:var(--surface-2);padding:10px;border-radius:8px;text-align:center"><div style="font-size:18px;font-weight:800;color:var(--blue)">15%</div><div style="font-size:10px;color:var(--text-3);margin-top:2px">Daily budget</div></div>
              <div style="background:var(--surface-2);padding:10px;border-radius:8px;text-align:center"><div style="font-size:18px;font-weight:800;color:var(--blue)">10%</div><div style="font-size:10px;color:var(--text-3);margin-top:2px">Buying type</div></div>
            </div>

            <p style="margin-bottom:12px"><strong style="color:var(--text-1)">Fórmula:</strong></p>
            <pre style="background:var(--surface-2);padding:12px;border-radius:8px;font-size:11px;color:var(--mint);overflow-x:auto;margin-bottom:14px">predicción_v2 = median(días de top-8 similares) − edad_actual

confidence = 40 + (matches × 7)   # 0 matches → 35%, 8 matches → 95%

si CPA &gt; 1.5x avg cuenta → predicción −= 3 días
si freq &gt; 5.0 → predicción = 0 (burnt)</pre>

            <p style="margin-bottom:12px"><strong style="color:var(--text-1)">Próximos pasos (Nivel 4):</strong></p>
            <ul style="padding-left:20px;color:var(--text-3)">
              <li>Random Forest sobre 30+ días de history archivado (ya estamos acumulando desde 2026-05-12)</li>
              <li>Survival analysis (Kaplan-Meier) sobre todas las campañas paused</li>
              <li>Auto-pause cuando confidence &gt; 90% y days_remaining = 0</li>
            </ul>
          </div>
        </details>
      </section>
      {% endif %}

      <!-- Campaigns table -->
      <section class="section" id="campaigns">
        <div class="section-head">
          <h2>Campañas <small>· ranked por score · click para abrir en Meta</small></h2>
          <span class="section-meta">{{ stats.campaigns_total }} · {{ stats.campaigns_scale }} scale · {{ stats.campaigns_monitor }} monitor · {{ stats.campaigns_stop }} stop</span>
        </div>
        <div class="campaigns-shell">
          <table class="campaigns-table">
            <thead>
              <tr>
                <th>Campaña</th>
                <th>Estado</th>
                <th class="right">Spend</th>
                <th class="right">Purchases</th>
                <th class="right">CPA</th>
                <th class="right">CTR</th>
                <th class="right">Freq</th>
                <th class="right">Duración</th>
                <th class="right">Score</th>
              </tr>
            </thead>
            <tbody>
              {% for c in campaigns %}
              <tr data-campaign-id="{{ c.id }}" data-account-id="{{ account.id }}" {% if c.status_label == 'HIDDEN WINNER' %}style="background:rgba(52,211,153,.04)"{% endif %}>
                <td>
                  <div class="camp-name">{% if c.status_label == 'HIDDEN WINNER' %}⭐ {% endif %}{{ c.name|truncate_smart(42) }}</div>
                  <div class="camp-meta">ID {{ c.id }} · {{ c.objective }} · {{ c.daily_budget|fmt }} daily{% if c.format_hint %} · {{ c.format_hint|upper }}{% endif %}</div>
                </td>
                <td><span class="status-dot status-{{ c.status_code }}">{{ c.status_label }}</span></td>
                <td class="right">{{ c.spend|fmt }}</td>
                <td class="right">{% if c.purchases == 0 %}<span style="color:var(--rose)">0</span>{% else %}{{ c.purchases }}{% endif %}</td>
                <td class="right">{% if c.cpa %}<span style="{% if c.cpa < summary.cpa * 0.7 %}color:var(--mint);font-weight:700{% elif c.cpa > summary.cpa * 1.3 %}color:var(--rose){% endif %}">{{ c.cpa|fmt }}</span>{% else %}<span style="color:var(--rose)">∞</span>{% endif %}</td>
                <td class="right" style="{% if c.ctr > summary.ctr * 1.5 %}color:var(--mint){% elif c.ctr < summary.ctr * 0.6 %}color:var(--rose){% endif %}">{{ c.ctr|round(2) }}%</td>
                <td class="right" style="{% if c.frequency > 3 %}color:var(--accent-2){% elif c.frequency < 2 %}color:var(--mint){% endif %}">{{ c.frequency|round(2) }}</td>
                <td class="right" data-tip="{{ c.duration.reason }} · freq {{ c.duration.freq_now }} · +{{ c.duration.freq_per_day }}/día · edad {{ c.duration.age_days or '?' }}d{% if c.duration.comparable_count %} · {{ c.duration.comparable_count }} similares (median {{ c.duration.comparable_median_days }}d){% endif %} · conf {{ c.duration.confidence }}%">
                  {% if c.duration.status == 'paused' %}
                    <span style="color:var(--text-4);font-size:11px">⏸ paused</span>
                  {% elif c.duration.status == 'fresh' %}
                    <span style="color:var(--mint);font-weight:700">{{ c.duration.days_remaining if c.duration.days_remaining < 60 else '60+' }}d</span><br><span style="font-size:10px;color:var(--text-4)">fresh · {{ c.duration.confidence }}%</span>
                  {% elif c.duration.status == 'healthy' %}
                    <span style="color:var(--mint)">{{ c.duration.days_remaining if c.duration.days_remaining < 60 else '60+' }}d</span><br><span style="font-size:10px;color:var(--text-4)">healthy · {{ c.duration.confidence }}%</span>
                  {% elif c.duration.status == 'warming' %}
                    <span style="color:var(--accent-2);font-weight:700">{{ c.duration.days_remaining }}d</span><br><span style="font-size:10px;color:var(--accent-2)">warming · {{ c.duration.confidence }}%</span>
                  {% elif c.duration.status == 'fatigued' %}
                    <span style="color:var(--accent);font-weight:700">{{ c.duration.days_remaining }}d</span><br><span style="font-size:10px;color:var(--accent)">fatigued · {{ c.duration.confidence }}%</span>
                  {% else %}
                    <span style="color:var(--rose);font-weight:700">0d</span><br><span style="font-size:10px;color:var(--rose)">🔥 burnt · {{ c.duration.confidence }}%</span>
                  {% endif %}
                </td>
                <td class="right">
                  <div class="score-badge">
                    <div class="score-bar"><div class="score-bar-fill" style="width:{{ c.score }}%;background:{% if c.score >= 80 %}var(--grad-mint){% elif c.score >= 50 %}linear-gradient(90deg,#FFB800,#FF5722){% else %}var(--grad-rose){% endif %}"></div></div>
                    <span class="score-num" style="color:{% if c.score >= 80 %}var(--mint){% elif c.score >= 50 %}var(--accent-2){% else %}var(--rose){% endif %}">{{ c.score|int }}</span>
                  </div>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>


      <!-- Activity Feed · Trazabilidad cross-platform -->
      {% if activity and activity.events %}
      <section class="section" id="activity">
        <div class="section-head">
          <h2>🕒 Activity Feed <small>· trazabilidad cross-platform · {{ activity.total_human }} cambios humanos · {{ activity.since }} → {{ activity.until }}</small></h2>
          <span class="section-meta">{{ activity.top_actors|length }} actores · top: {{ activity.top_actors[0].name if activity.top_actors else '—' }}</span>
        </div>

        <!-- Filtros + actors strip -->
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;align-items:center">
          <button class="actfilter active" data-platform="all" style="padding:6px 12px;border-radius:99px;background:rgba(255,87,34,.15);color:var(--accent);border:1px solid rgba(255,87,34,.3);font-size:12px;font-weight:600">Todos ({{ activity.total_human }})</button>
          <button class="actfilter" data-platform="meta" style="padding:6px 12px;border-radius:99px;background:rgba(24,119,242,.10);color:#6ba1f2;border:1px solid rgba(24,119,242,.25);font-size:12px;font-weight:500">Meta</button>
          <button class="actfilter" data-platform="shopify" style="padding:6px 12px;border-radius:99px;background:rgba(149,201,84,.10);color:#95C954;border:1px solid rgba(149,201,84,.25);font-size:12px;font-weight:500">Shopify</button>
          <span style="margin-left:12px;font-size:11px;color:var(--text-4)">· Top actores:</span>
          {% for a in activity.top_actors[:5] %}
          <button class="actfilter" data-actor="{{ a.name }}" style="padding:6px 12px;border-radius:99px;background:var(--surface-2);color:var(--text-2);border:1px solid var(--border);font-size:12px;font-weight:500">{{ a.name|truncate_smart(16) }} <span style="color:var(--text-4);font-weight:400">{{ a.count }}</span></button>
          {% endfor %}
        </div>

        <!-- Event timeline -->
        <div id="activity-list" style="display:flex;flex-direction:column;gap:6px;max-height:600px;overflow-y:auto;padding-right:8px">
          {% for e in activity.events[:200] %}
          {% if not e.is_system %}
          <div class="act-row" data-platform="{{ e.platform }}" data-actor="{{ e.actor }}" style="display:grid;grid-template-columns:80px 90px 1fr auto;gap:14px;align-items:center;padding:10px 14px;background:var(--surface-1);border:1px solid var(--border);border-radius:10px;font-size:12px{% if e.flag and e.flag.severity == 'critical' %};border-color:rgba(244,63,94,.35);background:rgba(244,63,94,.04){% elif e.flag and e.flag.severity == 'warning' %};border-color:rgba(255,184,0,.30);background:rgba(255,184,0,.04){% endif %}">
            <code style="color:var(--text-3);font-size:11px">{{ e.timestamp[:16].replace('T',' ') if e.timestamp else '—' }}</code>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.05em;padding:2px 8px;border-radius:6px;text-align:center;{% if e.platform == 'meta' %}background:rgba(24,119,242,.15);color:#6ba1f2{% elif e.platform == 'shopify' %}background:rgba(149,201,84,.15);color:#95C954{% elif e.platform == 'google' %}background:rgba(66,133,244,.15);color:#7BAEFF{% endif %}">{{ e.platform|upper }}</span>
            <div style="overflow:hidden">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px">
                <strong style="font-weight:700;color:var(--text-1)">{{ e.actor }}</strong>
                {% if e.flag %}<span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;padding:1px 6px;border-radius:4px;background:{% if e.flag.severity == 'critical' %}var(--rose){% elif e.flag.severity == 'warning' %}var(--accent-2){% else %}var(--blue){% endif %};color:#fff">🚩 {{ e.flag.label }}</span>{% endif %}
              </div>
              <span style="color:var(--text-2)">{{ e.event_label }} <span style="color:var(--text-3)">·</span> <em style="color:var(--text-3);font-style:normal">{{ e.object_name|truncate_smart(50) }}</em></span>
              {% if e.change_summary %}<div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-2);margin-top:2px">{{ e.change_summary }}</div>{% endif %}
            </div>
          </div>
          {% endif %}
          {% endfor %}
        </div>

        <p style="text-align:center;font-size:11px;color:var(--text-4);margin-top:12px">
          {% if activity.events|length >= 300 %}Mostrando primeros 200 · total cargado {{ activity.events|length }}{% else %}Total mostrado: {{ activity.events|length }}{% endif %}
          {% if activity.top_actors %} · Google Ads change_event pendiente — bloqueado por OAuth refresh token revoked.{% endif %}
        </p>
      </section>
      {% endif %}

      <!-- Post ID Intelligence -->
      {% if post_ids and post_ids|length > 0 %}
      <section class="section" id="post-ids">
        <div class="section-head">
          <h2>Post ID Intelligence <small>· consolidado cross-adset · click para copiar ID</small></h2>
          <span class="section-meta">{{ stats.post_ids_total }} posts · {{ stats.post_ids_with_purchases }} con conversiones</span>
        </div>
        <div class="post-list">
          {% for p in post_ids[:15] %}
          <div class="post-row" data-post-id="{{ p.post_id }}" data-story-id="{{ p.story_id }}">
            <div class="post-rank{% if loop.index <= 3 %} top{% endif %}">{{ '%02d' % loop.index }}</div>
            <div class="post-thumb">
              {% if p.thumbnail_url %}<img src="{{ p.thumbnail_url }}" alt="thumb" onerror="this.style.display='none'">{% else %}POST<br>{{ p.post_id[-4:] if p.post_id else '?' }}{% endif %}
            </div>
            <div class="post-meta">
              <h4>{{ p.ad_names[0]|truncate_smart(46) if p.ad_names else 'Post ' + p.post_id[-12:] }}</h4>
              <p>id …{{ p.post_id[-12:] if p.post_id else '' }} · {{ p.ad_count }} ad{{ 's' if p.ad_count != 1 else '' }}{% if p.active_count %} · {{ p.active_count }} active{% endif %} · {{ p.adsets_count }} adset{{ 's' if p.adsets_count != 1 else '' }}</p>
              <div class="post-tags">
                {% set tag_class = p.label|lower|replace(' ', '-') %}
                <span class="post-tag {{ tag_class }}">{{ p.label }}</span>
                {% if p.frequency > 4 %}<span class="post-tag fatigued">freq {{ p.frequency|round(1) }}</span>{% endif %}
              </div>
            </div>
            <div class="hide-md">
              <div class="post-stat-num" style="{% if p.cpa and summary.cpa and p.cpa < summary.cpa * 0.7 %}color:var(--mint){% elif p.cpa and summary.cpa and p.cpa > summary.cpa * 1.3 %}color:var(--rose){% endif %}">{{ p.cpa|fmt }}</div>
              <div class="post-stat-label">CPA</div>
            </div>
            <div class="hide-md">
              <div class="post-stat-num">{{ p.purchases }}</div>
              <div class="post-stat-label">PURCHASES</div>
            </div>
            <div class="hide-md">
              <div class="post-stat-num">{{ p.spend|fmt }}</div>
              <div class="post-stat-label">SPEND</div>
            </div>
            <div>
              <div class="post-stat-num">{{ p.ctr|round(2) }}%</div>
              <div class="post-stat-label">CTR</div>
            </div>
          </div>
          {% endfor %}
        </div>
        {% if post_ids|length > 15 %}
        <p style="margin-top:14px;font-size:12px;color:var(--text-3);text-align:center">Mostrando top 15 de {{ post_ids|length }} posts. Resto disponible en el JSON.</p>
        {% endif %}
      </section>
      {% endif %}

      <!-- Audience Intelligence -->
      {% if audience and audience.age_gender %}
      <section class="section" id="audience">
        <div class="section-head">
          <h2>Audience Intelligence <small>· demographics + placement + geo</small></h2>
          <span class="section-meta">Breakdown account-level</span>
        </div>

        <div class="audience-grid">
          <!-- Age + Gender -->
          <div class="audience-card">
            <h3>🎯 Performance por edad + género</h3>
            <div class="demo-bars">
              {% set max_purch = audience.age_gender|map(attribute='purchases')|max %}
              {% for d in audience.age_gender[:8] %}
              <div class="demo-bar">
                <div class="demo-bar-label">
                  {{ d.age }}
                  <span class="gender-pill {{ d.gender }}">{{ d.gender[:1]|upper }}</span>
                </div>
                <div class="demo-bar-track">
                  <div class="demo-bar-fill {{ d.gender }}" style="width: {{ (d.purchases / max_purch * 100) if max_purch else 0 }}%"></div>
                </div>
                <div class="demo-bar-val">{{ d.purchases }} <span style="color:var(--text-3);font-weight:500">({{ d.purchase_share|round(0)|int }}%)</span></div>
                <div class="demo-bar-cpa">{{ (d.cpa / 1000)|round(0)|int if d.cpa else '—' }}{% if d.cpa %}K{% endif %}</div>
              </div>
              {% endfor %}
            </div>
            {% if audience.gender_split %}
            <div class="audience-summary">
              <strong>{{ audience.gender_split.male_pct|round(0)|int }}% hombres / {{ audience.gender_split.female_pct|round(0)|int }}% mujeres</strong> de las compras. Top demo: <strong>{{ audience.top_demo.label }}</strong> con {{ audience.top_demo.purchases }} purchases ({{ audience.top_demo.purchase_share|round(0)|int }}%).
            </div>
            {% endif %}
          </div>

          <!-- Placement + Country -->
          <div class="audience-card">
            <h3>📍 Top placements</h3>
            <div class="placement-list">
              {% set max_pl_share = audience.placement|map(attribute='purchase_share')|max if audience.placement else 1 %}
              {% for pl in audience.placement[:6] %}
              <div class="placement-row">
                <div class="placement-bar" style="width: {{ (pl.purchase_share / max_pl_share * 100) if max_pl_share else 0 }}%"></div>
                <span class="placement-name">{{ pl.label }}</span>
                <span class="placement-share">{{ pl.purchases }} buy</span>
                <span class="placement-share" style="color:var(--text-2)">{{ pl.purchase_share|round(0)|int }}%</span>
              </div>
              {% endfor %}
            </div>

            {% if audience.region %}
            {% set total_region_spend = audience.region|sum(attribute='spend') %}
            <h3 style="margin-top:24px">📍 Regiones <small style="color:var(--text-3);font-weight:500;font-size:11px">· top por spend · clicks/CPC reales</small></h3>
            <div class="country-strip">
              {% for re in audience.region[:8] %}
              <div class="country-row">
                <span class="country-flag">📍</span>
                <span class="country-name">{{ re.region }}</span>
                <span class="country-stat">
                  {{ re.clicks|int }} clk
                  <span style="color:var(--text-3);font-weight:500">· ${{ (re.spend / 1000)|round(0)|int }}K</span>
                  <span style="color:var(--text-3);font-weight:500">· {{ ((re.spend / total_region_spend * 100) if total_region_spend else 0)|round(0)|int }}%</span>
                </span>
              </div>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
      </section>
      {% endif %}

      <!-- Recommendations -->
      {% if recommendations %}
      <section class="section" id="recommendations">
        <div class="section-head">
          <h2>Recomendaciones AI <small>· basadas en data real</small></h2>
          <span class="section-meta">{{ recommendations|length }} acciones priorizadas</span>
        </div>
        <div class="recos-list">
          {% for r in recommendations %}
          <div class="reco-card">
            <div class="reco-icon {{ r.icon_class }}">{{ r.icon }}</div>
            <div class="reco-body">
              <h4>{{ r.title }}</h4>
              <p>{{ r.description|safe }}</p>
            </div>
            <span class="reco-priority {{ r.priority }}">{{ r.priority_label }}</span>
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- Footer -->
      <div style="margin-top:60px;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;font-size:12px;color:var(--text-4);flex-wrap:wrap;gap:14px">
        <span>Serene · AI Performance Command Center · v3.0 — Python engine</span>
        <span>{{ account.id }} · Generado {{ generated_at }}</span>
      </div>

    </main>
  </div>

  <!-- ─── Detail Modal ─── -->
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal" id="modal">
      <div class="modal-head">
        <div style="flex:1">
          <span class="modal-tag" id="modal-tag">CRITICAL</span>
          <h3 id="modal-title">—</h3>
          <p class="subtitle" id="modal-subtitle">—</p>
        </div>
        <button class="modal-close" id="modal-close" aria-label="Cerrar">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>

  <!-- Embed urgent_actions data as JSON for the modal -->
  {% if urgent_actions %}
  <script id="urgent-data" type="application/json">{{ urgent_actions|tojson }}</script>
  {% endif %}

  <script>
  (function(){
    'use strict';

    // ── Mobile sidebar drawer ──
    const sidebar = document.querySelector('.sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');
    const btnMenu = document.getElementById('btn-menu');

    function openDrawer(){
      sidebar.classList.add('open');
      backdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer(){
      sidebar.classList.remove('open');
      backdrop.classList.remove('active');
      document.body.style.overflow = '';
    }
    if (btnMenu) btnMenu.addEventListener('click', openDrawer);
    backdrop.addEventListener('click', closeDrawer);
    // Close drawer on link click (mobile UX) + smooth scroll fallback
    document.querySelectorAll('.sidebar-link').forEach(l => {
      l.addEventListener('click', (ev) => {
        const href = l.getAttribute('href') || '';
        if (href.startsWith('#')) {
          const target = document.querySelector(href);
          if (target) {
            ev.preventDefault();
            const y = target.getBoundingClientRect().top + window.scrollY - 16;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        }
        if (window.innerWidth <= 1024) setTimeout(closeDrawer, 250);
      });
    });
    // Close drawer on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && sidebar.classList.contains('open')) closeDrawer();
    });

    // ── Toast helper ──
    const toastEl = document.getElementById('toast');
    let toastTimer;
    function toast(msg, type='success', ms=2400){
      toastEl.textContent = msg;
      toastEl.className = 'toast show ' + type;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toastEl.classList.remove('show'), ms);
    }

    // ── Scroll progress bar ──
    const bar = document.getElementById('scrollProgress');
    function updateProgress(){
      const h = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = h > 0 ? (window.scrollY / h * 100) + '%' : '0%';
    }
    window.addEventListener('scroll', updateProgress, {passive:true});
    updateProgress();

    // ── Sidebar scroll-spy + click ──
    const links = document.querySelectorAll('.sidebar-link[data-target]');
    const sections = Array.from(links).map(l => document.getElementById(l.dataset.target)).filter(Boolean);

    function setActive(id){
      links.forEach(l => l.classList.toggle('active', l.dataset.target === id));
    }
    if (sections.length) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) setActive(e.target.id);
        });
      }, { rootMargin: '-30% 0px -60% 0px' });
      sections.forEach(s => obs.observe(s));
    }

    // ── Campaign row → open Meta Ads Manager ──
    document.querySelectorAll('.campaigns-table tbody tr[data-campaign-id]').forEach(tr => {
      tr.addEventListener('click', () => {
        const camp = tr.dataset.campaignId;
        const act = (tr.dataset.accountId || '').replace(/^act_/, '');
        if (!camp || !act) return;
        const url = `https://business.facebook.com/adsmanager/manage/adsets?act=${act}&selected_campaign_ids=${camp}`;
        window.open(url, '_blank', 'noopener');
        toast(`Abriendo "${tr.querySelector('.camp-name')?.textContent || 'campaña'}" en Meta Ads`, 'success');
      });
    });

    // ── Post row → copy post_id + offer link ──
    document.querySelectorAll('.post-row[data-post-id]').forEach(row => {
      row.addEventListener('click', async (e) => {
        const pid = row.dataset.postId;
        const sid = row.dataset.storyId;
        try {
          await navigator.clipboard.writeText(pid);
          toast(`Post ID copiado: ${pid.slice(-12)}`, 'success');
        } catch(err) {
          toast('No se pudo copiar — usa Ctrl+C', 'error');
        }
        // If shift-click, also open the post in Facebook
        if (e.shiftKey && sid) {
          window.open(`https://facebook.com/${sid}`, '_blank', 'noopener');
        }
      });
    });

    // ── Urgent action card → open modal with details ──
    const urgentDataEl = document.getElementById('urgent-data');
    const urgentData = urgentDataEl ? JSON.parse(urgentDataEl.textContent) : [];
    const overlay = document.getElementById('modal-overlay');
    const modalTag = document.getElementById('modal-tag');
    const modalTitle = document.getElementById('modal-title');
    const modalSubtitle = document.getElementById('modal-subtitle');
    const modalBody = document.getElementById('modal-body');
    const modalClose = document.getElementById('modal-close');

    function openModal(idx){
      const a = urgentData[idx];
      if (!a || !a.detail) return;
      const sev = a.severity || 'critical';
      modalTag.className = 'modal-tag ' + sev;
      modalTag.textContent = a.action || 'ACCIÓN';
      modalTitle.textContent = a.target_name || '';
      modalSubtitle.textContent = a.reason || '';

      let html = '';
      if (a.detail.what) {
        html += '<h4>¿Qué pasa?</h4><p>' + escapeHTML(a.detail.what) + '</p>';
      }
      if (a.detail.why_kill) {
        html += '<h4>Por qué actuar</h4><p>' + escapeHTML(a.detail.why_kill) + '</p>';
      }
      if (a.detail.steps && a.detail.steps.length) {
        html += '<h4>Paso a paso</h4><div class="modal-steps">';
        a.detail.steps.forEach((s, i) => {
          html += `<div class="modal-step">
            <div class="modal-step-num">${i+1}</div>
            <div class="modal-step-body">
              <h5>${escapeHTML(s.title)}</h5>
              <p>${escapeHTML(s.desc)}</p>
            </div>
          </div>`;
        });
        html += '</div>';
      }
      if (a.detail.post_action) {
        html += '<div class="modal-callout">' + escapeHTML(a.detail.post_action) + '</div>';
      }
      if (a.detail.external_links && a.detail.external_links.length) {
        html += '<h4>Acciones directas</h4><div class="modal-links">';
        a.detail.external_links.forEach(link => {
          html += `<a class="modal-link" href="${escapeAttr(link.url)}" target="_blank" rel="noopener">${escapeHTML(link.label)}</a>`;
        });
        html += '</div>';
      }
      modalBody.innerHTML = html;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(){
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.urgent-card[data-urgent-idx]').forEach(card => {
      card.addEventListener('click', () => {
        const idx = parseInt(card.dataset.urgentIdx, 10);
        openModal(idx);
      });
    });
    modalClose.addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && overlay.classList.contains('active')) closeModal(); });

    function escapeHTML(s){
      return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escapeAttr(s){
      return String(s ?? '').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    // ── Refresh button → triggers GitHub workflow_dispatch ──
    const btnRegen = document.getElementById('btn-regen');
    if (btnRegen) {
      btnRegen.addEventListener('click', () => {
        // Open the GitHub Actions page directly — user clicks "Run workflow"
        // (We can't trigger workflow_dispatch from frontend without a PAT exposed)
        window.open('https://github.com/sereneleparfumteam-glitch/serene-dashboard/actions/workflows/daily.yml', '_blank', 'noopener');
        toast('Abriendo GitHub Actions — click "Run workflow"', 'success', 3500);
      });
    }

    // ── Print button ──
    const btnPrint = document.getElementById('btn-print');
    if (btnPrint) btnPrint.addEventListener('click', () => window.print());

    // ── Pill toggles (visual only, with feedback) ──
    document.querySelectorAll('.pill-group').forEach(group => {
      group.querySelectorAll('.pill-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          group.querySelectorAll('.pill-toggle').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          toast(`Filtro "${btn.textContent.trim()}" — pendiente: regenerar con ese rango`, 'success', 2800);
        });
      });
    });

    // ── Sortable campaign table ──
    document.querySelectorAll('.campaigns-table thead th').forEach((th, idx) => {
      if (idx === 0 || idx === 1) return; // skip name + status
      th.style.cursor = 'pointer';
      th.style.userSelect = 'none';
      let asc = false;
      th.addEventListener('click', () => {
        const tbody = th.closest('table').querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => {
          const av = a.cells[idx].textContent.trim();
          const bv = b.cells[idx].textContent.trim();
          const an = parseFloat(av.replace(/[^\d.-]/g, '')) || 0;
          const bn = parseFloat(bv.replace(/[^\d.-]/g, '')) || 0;
          return asc ? an - bn : bn - an;
        });
        asc = !asc;
        rows.forEach(r => tbody.appendChild(r));
        toast(`Ordenado por ${th.textContent.trim()} ${asc ? '↓' : '↑'}`, 'success', 1500);
      });
    });

    // Activity Feed filters
    const actFilters = document.querySelectorAll('.actfilter');
    const actRows = document.querySelectorAll('.act-row');
    let currentPlatform = 'all';
    let currentActor = null;
    function applyActFilter() {
      actRows.forEach(r => {
        const p = r.getAttribute('data-platform');
        const a = r.getAttribute('data-actor');
        const matchP = currentPlatform === 'all' || p === currentPlatform;
        const matchA = !currentActor || a === currentActor;
        r.style.display = (matchP && matchA) ? '' : 'none';
      });
    }
    actFilters.forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.hasAttribute('data-platform')) {
          currentPlatform = btn.getAttribute('data-platform');
          document.querySelectorAll('.actfilter[data-platform]').forEach(b => {
            b.classList.remove('active');
            b.style.background = 'var(--surface-2)';
            b.style.color = 'var(--text-2)';
            b.style.borderColor = 'var(--border)';
          });
          btn.classList.add('active');
          btn.style.background = 'rgba(255,87,34,.15)';
          btn.style.color = 'var(--accent)';
          btn.style.borderColor = 'rgba(255,87,34,.3)';
        } else if (btn.hasAttribute('data-actor')) {
          const a = btn.getAttribute('data-actor');
          currentActor = (currentActor === a) ? null : a;
          document.querySelectorAll('.actfilter[data-actor]').forEach(b => {
            b.style.background = 'var(--surface-2)';
            b.style.color = 'var(--text-2)';
            b.style.borderColor = 'var(--border)';
          });
          if (currentActor) {
            btn.style.background = 'rgba(99,102,241,.15)';
            btn.style.color = 'var(--blue)';
            btn.style.borderColor = 'rgba(99,102,241,.3)';
          }
        }
        applyActFilter();
      });
    });

    console.log('✓ Dashboard interactive layer loaded');
  })();
  </script>
</body>
</html>
